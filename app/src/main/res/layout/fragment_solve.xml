<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_solve.xml
    Two full-screen panels share the same FrameLayout root;
    only one is visible at a time (toggled by SolveFragment).

    Panel 1 – groupInput  : image picker + extra text + solve button + progress
    Panel 2 – layoutResult: thumbnail header + WebView (KaTeX) + action bar
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- ══════════════════════════════════════════════════════════
         PANEL 1 – Input form
         ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/groupInput"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Problem image preview -->
        <ImageView
            android:id="@+id/ivPreview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_image_placeholder"
            android:contentDescription="Ảnh bài toán"
            android:scaleType="centerCrop" />

        <!-- Gallery / Camera buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGallery"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Thư viện" />

            <Button
                android:id="@+id/btnCamera"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Camera" />
        </LinearLayout>

        <!-- Optional extra question -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Câu hỏi thêm (tùy chọn)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etExtraText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:maxLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Solve button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSolve"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:enabled="false"
            android:text="✨ Giải bài"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#4F46E5"
            app:cornerRadius="12dp" />

        <!-- Loading indicator (visible during API call) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:id="@+id/layoutLoading">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorColor="#4F46E5"
                app:indicatorSize="48dp"
                app:trackColor="#E0E7FF"
                app:trackThickness="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="AI đang phân tích bài..."
                android:textColor="#64748B"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════
         PANEL 2 – Result display (WebView + KaTeX)
         ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- ── Result header card ───────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="0dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:orientation="horizontal">

                <!-- Problem thumbnail -->
                <ImageView
                    android:id="@+id/ivThumbnail"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_image_placeholder"
                    android:clipToOutline="true"
                    android:contentDescription="Ảnh bài toán" />

                <!-- Title + subtitle -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lời giải chi tiết"
                        android:textColor="#0F172A"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Powered by Gemini AI"
                        android:textColor="#64748B"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Gemini AI badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#EEF2FF"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="AI"
                    android:textColor="#4F46E5"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── WebView: scrollable solution with KaTeX ───────────── -->
        <WebView
            android:id="@+id/webViewAnswer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF" />

        <!-- ── Bottom action bar ─────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="0dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp">

                <Button
                    android:id="@+id/btnCopy"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="Chép"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnShare"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="Chia sẻ"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReset"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1.5"
                    android:text="← Câu mới"
                    android:textSize="13sp"
                    app:backgroundTint="#4F46E5"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</FrameLayout>
