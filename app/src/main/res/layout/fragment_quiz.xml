<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="20dp">

    <!-- Progress bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_quiz"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:progress="20"
        app:indicatorColor="#4F46E5"
        app:trackColor="#E2E8F0"
        app:trackCornerRadius="4dp"
        app:trackThickness="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Chỉ số câu hỏi -->
    <TextView
        android:id="@+id/tv_question_index"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Câu 1/5"
        android:textColor="#64748B"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/progress_quiz" />

    <!-- Card nội dung -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_question_index"
        app:strokeWidth="0dp">

        <TextView
            android:id="@+id/tv_question_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:text="Nội dung câu hỏi hiển thị tại đây. Giải phương trình bậc 2 sau: x² - 4x + 4 = 0?"
            android:textColor="#0F172A"
            android:textSize="22sp"
            android:textStyle="bold"
            android:lineSpacingExtra="6dp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Các lựa chọn đáp án -->
    <RadioGroup
        android:id="@+id/rg_answers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/card_question">

        <RadioButton
            android:id="@+id/rb_answer_a"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_radio_button"
            android:padding="20dp"
            android:text="A. x = 2"
            android:textColor="#334155"
            android:textSize="18sp"
            android:buttonTint="#4F46E5" />

        <RadioButton
            android:id="@+id/rb_answer_b"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_radio_button"
            android:padding="20dp"
            android:text="B. x = -2"
            android:textColor="#334155"
            android:textSize="18sp"
            android:buttonTint="#4F46E5" />

        <RadioButton
            android:id="@+id/rb_answer_c"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_radio_button"
            android:padding="20dp"
            android:text="C. Vô nghiệm"
            android:textColor="#334155"
            android:textSize="18sp"
            android:buttonTint="#4F46E5" />

        <RadioButton
            android:id="@+id/rb_answer_d"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_radio_button"
            android:padding="20dp"
            android:text="D. Vô số nghiệm"
            android:textColor="#334155"
            android:textSize="18sp"
            android:buttonTint="#4F46E5" />
    </RadioGroup>

    <!-- Nút xác nhận -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_submit_next"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:text="Xác nhận"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="#4F46E5"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
