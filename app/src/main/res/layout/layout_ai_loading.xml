<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000"
    android:elevation="24dp"
    android:clickable="true"
    android:focusable="true">
    <!-- Đặt background đen trong suốt (#B3000000) và clickable="true" chặn thao tác nền -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_ai_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1A1A24"
        app:cardCornerRadius="20dp"
        app:cardElevation="16dp"
        app:strokeColor="#00E5FF"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_ai_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorColor="#00E5FF"
                app:indicatorSize="64dp"
                app:trackColor="#001F3F"
                app:trackCornerRadius="4dp"
                app:trackThickness="6dp" />

            <TextView
                android:id="@+id/tv_ai_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="AI đang phân tích và giải bài..."
                android:textColor="#E0F7FA"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
